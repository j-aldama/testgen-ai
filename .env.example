# TestGen Configuration
# Copy this file to .env and fill in your values

# Required: LLM Provider (anthropic or openai)
# TESTGEN_LLM_PROVIDER=anthropic

# --- Anthropic (default) ---
TESTGEN_ANTHROPIC_API_KEY=your-api-key-here
# TESTGEN_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- OpenAI-compatible (OpenAI, Azure, Ollama, LM Studio, etc.) ---
# TESTGEN_OPENAI_API_KEY=your-openai-key-here
# TESTGEN_OPENAI_MODEL=gpt-4o
# TESTGEN_OPENAI_BASE_URL=http://localhost:11434/v1  # Ollama example

# Optional: Shared LLM settings
# TESTGEN_MAX_TOKENS=8192
# TESTGEN_TEMPERATURE=0.3

# Optional: Web server configuration
# TESTGEN_WEB_HOST=0.0.0.0
# TESTGEN_WEB_PORT=8000

# Optional: Output directory (default: ./output)
# TESTGEN_OUTPUT_DIR=./output
